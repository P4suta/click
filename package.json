{
  "name": "click",
  "version": "0.1.0",
  "private": true,
  "description": "A modern, offline-first music practice metronome",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun --filter '@click/web' dev",
    "build": "bun --filter '@click/core' build && bun --filter '@click/web' build",
    "test": "bun --filter '*' test",
    "test:core": "bun --filter '@click/core' test",
    "test:web": "bun --filter '@click/web' test",
    "test:watch": "bun --filter '@click/core' test:watch",
    "test:coverage": "bun --filter '*' test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -b",
    "ci": "bun run lint && bun run typecheck && bun run test:coverage && bun run build",
    "mutation": "bun --filter '@click/core' mutation",
    "preview": "bun --filter '@click/web' preview"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "typescript": "6.0.2"
  }
}
